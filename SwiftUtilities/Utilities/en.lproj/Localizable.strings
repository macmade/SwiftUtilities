/* Title of the About window. %@ is the application name. */
"About.window.title" = "About %@";

/* Title of the Credits window. */
"Credits.window.title" = "Credits";

/* Placeholder shown in the Credits window's detail pane when no project is selected. */
"Credits.placeholder" = "This application makes use of the following third-party projects.";

/* Title of the alert shown when an update check fails. */
"GitHubUpdater.alert.error.title" = "Error";

/* Title of the alert shown when the application is already up-to-date. */
"GitHubUpdater.alert.upToDate.title" = "You're up-to-date!";

/* Body of the up-to-date alert. %1$@ is the application name, %2$@ the current version. */
"GitHubUpdater.alert.upToDate.message" = "%1$@ %2$@ is currently the newest available version.";

/* Title of the update-available window. */
"GitHubUpdater.window.title" = "Update Available";

/* Heading of the update-available window. %1$@ is the application name, %2$@ the available version. */
"GitHubUpdater.window.heading" = "%1$@ %2$@ is available";

/* Subtitle of the update-available window. %1$@ is the current version. */
"GitHubUpdater.window.subtitle" = "You're currently on version %1$@.";

/* Button downloading the update from the update-available window. */
"GitHubUpdater.window.button.download" = "Download";

/* Button opening the release page on GitHub from the update-available window. */
"GitHubUpdater.window.button.view" = "View on GitHub";

/* Button dismissing the update-available window without downloading. */
"GitHubUpdater.window.button.later" = "Later";

/* Button downloading and installing the update in place, in the in-app update window. */
"GitHubUpdater.window.button.install" = "Download & Install";

/* Status shown while the in-app update is downloading. */
"GitHubUpdater.window.status.downloading" = "Downloading update…";

/* Status shown while the in-app update is installing. */
"GitHubUpdater.window.status.installing" = "Installing update…";

/* Status shown while the application is relaunching into the new version. */
"GitHubUpdater.window.status.relaunching" = "Relaunching…";

/* Message shown when the update has been installed and is ready to relaunch. */
"GitHubUpdater.window.status.installed" = "The update has been installed and is ready to use.";

/* Button relaunching the application into the newly installed version. */
"GitHubUpdater.window.button.relaunch" = "Relaunch";

/* Title shown in the in-app update window when the update fails. */
"GitHubUpdater.window.error.title" = "The update could not be installed.";
